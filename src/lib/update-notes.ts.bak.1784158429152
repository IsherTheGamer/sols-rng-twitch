function parsePage(query: string): number {
  const first = query.trim().toLowerCase().split(/\s+/)[0] ?? "1";
  if (first === "latest" || first === "new") return 1;
  const n = Number(first.replace(/,/g, ""));
  return Number.isFinite(n) ? Math.max(1, Math.floor(n)) : 1;
}

export function formatUpdateNotes(query = ""): string {
  const page = Math.min(parsePage(query), UPDATE_NOTES.length);
  return truncate(`🛠️ Update ${page}/${UPDATE_NOTES.length}: ${UPDATE_NOTES[page - 1]}`, 390);
}
