} from "./fuzzy-alias";

export type TwitchCommandCategory =
  | "progression"
  | "rng"
  | "activity"
  | "social"
  | "information"
  | "admin";

export interface TwitchCommandDefinition {
  name: string;
  endpoint: string;
  description: string;
  category: TwitchCommandCategory;
  aliases: readonly string[];
  requiresLink: boolean;
  adminOnly: boolean;
}

interface CommandOptions {
  endpoint?: string;
  aliases?: readonly string[];
  requiresLink?: boolean;
  adminOnly?: boolean;
}

function command(
  name: string,
  description: string,
  category: TwitchCommandCategory,
  options: CommandOptions = {}
): TwitchCommandDefinition {
  return {
    name,
    endpoint: options.endpoint ?? name,
    description,
    category,
    aliases: options.aliases ?? [],
    requiresLink: options.requiresLink ?? true,
    adminOnly: options.adminOnly ?? false,
  };
}

