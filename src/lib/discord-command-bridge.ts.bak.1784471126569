const COMMAND_CANDIDATES: AliasCandidate<TwitchCommandDefinition>[] =
  TWITCH_COMMANDS.map((entry) => ({
    id: entry.name,
    label: `!${entry.name}`,
    aliases: [entry.name, `!${entry.name}`, ...entry.aliases],
    value: entry,
  }));

export function getTwitchCommand(
  name: string | undefined | null
): TwitchCommandDefinition | null {
  const clean = String(name ?? "")
    .trim()
    .toLowerCase()
    .replace(/^!+/, "");

  return TWITCH_COMMANDS.find((entry) => entry.name === clean) ?? null;
}

export function resolveTwitchCommand(raw: string): {
  command?: TwitchCommandDefinition;
  error?: string;
} {
  const result = resolveAlias(raw, COMMAND_CANDIDATES, {
    maxScore: 0.3,
    ambiguityGap: 0.065,
  });

  if (result.status === "matched") {
    return { command: result.match.value };
  }

  return {
    error: aliasSuggestionText(result, "Twitch command"),
  };
}

export function autocompleteTwitchCommands(
  raw: string,
  limit = 25
): Array<{ name: string; value: string }> {
  const query = raw.trim().toLowerCase().replace(/^!+/, "");

  const ranked = TWITCH_COMMANDS.map((entry) => {
    const names = [entry.name, ...entry.aliases].map((value) =>
      value.toLowerCase()
    );

    let score = 3;

    if (!query) score = 2;
    else if (names.some((value) => value === query)) score = 0;
    else if (names.some((value) => value.startsWith(query))) score = 0.5;
    else if (names.some((value) => value.includes(query))) score = 1;
    else if (
      entry.description.toLowerCase().includes(query) ||
      entry.category.includes(query as TwitchCommandCategory)
    ) {
      score = 1.5;
    }

    return { entry, score };
  })
    .filter((item) => item.score < 3)
    .sort(
      (a, b) =>
        a.score - b.score || a.entry.name.localeCompare(b.entry.name)
    )
    .slice(0, Math.max(1, Math.min(25, limit)));

  return ranked.map(({ entry }) => ({
    name: `/${entry.name} — ${entry.description}`.slice(0, 100),
    value: entry.name,
  }));
}

export function formatTwitchCommandCatalog(
  rawQuery = "",
  rawPage = "1",
  rawCategory = "all"
): string {
  const query = rawQuery.trim().toLowerCase().replace(/^!+/, "");
  const category = rawCategory.trim().toLowerCase();
  const page = Math.max(1, Math.floor(Number(rawPage) || 1));

  const filtered = TWITCH_COMMANDS.filter((entry) => {
    if (category !== "all" && entry.category !== category) return false;
    if (!query) return true;

    return [
      entry.name,
      entry.description,
      entry.category,
      ...entry.aliases,
    ].some((value) => value.toLowerCase().includes(query));
  });

  if (filtered.length === 0) {
    return "No matching Twitch commands. Try /sols commands with a shorter search.";
  }

  const size = 10;
  const total = Math.max(1, Math.ceil(filtered.length / size));
  const safePage = Math.min(page, total);
  const shown = filtered.slice((safePage - 1) * size, safePage * size);

  return [
    `🎮 Twitch Commands ${safePage}/${total} (${filtered.length}/${TWITCH_COMMANDS.length})`,
    shown
      .map(
        (entry) =>
          `/${entry.name}${entry.adminOnly ? " [ADMIN]" : ""} — ${
            entry.description
          }`
      )
      .join(" | "),
    "Use the direct slash command, or /sols run for typo/fuzzy input.",
  ]
    .join(" | ")
    .slice(0, 1900);
}

export interface DiscordTwitchLink {
  guildId: string;
  discordUserId: string;
  twitchUserId: string;
  twitchUsername: string;
  twitchDisplayName: string;
  linkedAt: number;
  linkedByDiscordUserId: string;
}

let redis: Redis | null | undefined;

function getRedis(): Redis | null {
  if (redis !== undefined) return redis;

  const url = process.env.UPSTASH_REDIS_REST_URL;
  const token = process.env.UPSTASH_REDIS_REST_TOKEN;
  redis = url && token ? new Redis({ url, token }) : null;
  return redis;
}

function guildScope(guildId: string | undefined | null): string {
  return (
    String(guildId ?? "").trim() ||
    String(process.env.DISCORD_GUILD_ID ?? "").trim() ||
    "global"
  );
}

function linkKey(
  guildId: string | undefined | null,
  discordUserId: string
): string {
  return `discord:twitch-link:${guildScope(guildId)}:${discordUserId}`;
}

function cleanDiscordId(raw: string): string {
  return raw.trim().replace(/[^0-9]/g, "");
}

function cleanTwitchId(raw: string): string {
  return raw.trim().replace(/[^0-9]/g, "");
}

function cleanTwitchUsername(raw: string): string {
  return raw
    .trim()
    .replace(/^@+/, "")
    .toLowerCase()
    .replace(/[^a-z0-9_]/g, "");
}

export async function getDiscordTwitchLink(
  guildId: string | undefined | null,
  discordUserId: string
): Promise<DiscordTwitchLink | null> {
  const r = getRedis();
  const cleanDiscord = cleanDiscordId(discordUserId);

  if (!r || !cleanDiscord) return null;
  return r.get<DiscordTwitchLink>(linkKey(guildId, cleanDiscord));
}

export async function setDiscordTwitchLink(input: {
  guildId?: string | null;
  discordUserId: string;
  twitchUserId: string;
  twitchUsername: string;
  twitchDisplayName?: string;
  linkedByDiscordUserId: string;
}): Promise<DiscordTwitchLink> {
  const r = getRedis();
  if (!r) throw new Error("Redis is not connected.");

  const discordUserId = cleanDiscordId(input.discordUserId);
  const twitchUserId = cleanTwitchId(input.twitchUserId);
  const twitchUsername = cleanTwitchUsername(input.twitchUsername);

  if (!discordUserId) throw new Error("Enter a valid Discord user.");
  if (!twitchUserId) throw new Error("Enter the numeric Twitch user ID.");
  if (!twitchUsername) throw new Error("Enter the Twitch username.");

  const link: DiscordTwitchLink = {
    guildId: guildScope(input.guildId),
    discordUserId,
    twitchUserId,
    twitchUsername,
    twitchDisplayName:
      input.twitchDisplayName?.trim() || input.twitchUsername.trim(),
    linkedAt: Date.now(),
    linkedByDiscordUserId: cleanDiscordId(input.linkedByDiscordUserId),
  };

  await r.set(linkKey(input.guildId, discordUserId), link);
  return link;
}

export async function removeDiscordTwitchLink(
  guildId: string | undefined | null,
  discordUserId: string
): Promise<boolean> {
  const r = getRedis();
  const cleanDiscord = cleanDiscordId(discordUserId);

  if (!r || !cleanDiscord) return false;

  const key = linkKey(guildId, cleanDiscord);
  const existing = await r.get<DiscordTwitchLink>(key);
  if (!existing) return false;

  await r.del(key);
  return true;
}

export function formatDiscordTwitchLink(
  link: DiscordTwitchLink | null,
  discordUserId: string
): string {
  if (!link) {
    return `🔗 Discord <@${discordUserId}> is not linked to a Twitch save. Ask a Discord admin to use /sols link.`;
  }

  return `🔗 Discord <@${discordUserId}> → Twitch ${link.twitchDisplayName} (@${link.twitchUsername}, ID ${link.twitchUserId}).`;
}

export interface DiscordBridgeUser {
  id: string;
  username: string;
  globalName?: string | null;
}

function firstHeader(
  value: string | string[] | undefined
): string {
  return Array.isArray(value) ? value[0] ?? "" : value ?? "";
}

function requestOrigin(req: NextApiRequest): string {
  const forwardedProto =
    firstHeader(req.headers["x-forwarded-proto"]) || "https";
  const forwardedHost =
    firstHeader(req.headers["x-forwarded-host"]) ||
    firstHeader(req.headers.host);

  if (forwardedHost) {
    return `${forwardedProto}://${forwardedHost}`;
  }

  const vercelUrl = process.env.VERCEL_URL;
  if (vercelUrl) return `https://${vercelUrl}`;

  return "http://localhost:3000";
}

function encodeHeaderValues(
  values: Record<string, string>
): string {
  return Object.entries(values)
    .map(
      ([key, value]) =>
        `${key}=${encodeURIComponent(String(value ?? ""))}`
    )
    .join("&");
}

function cleanReply(content: string): string {
  const clean = content.replace(/\s+/g, " ").trim();
  return (clean || "Command completed with no text response.").slice(0, 1900);
}

function splitRawCommand(
  rawCommand: string,
  rawArguments: string
): { commandText: string; argumentsText: string } {
  const cleanCommand = rawCommand.trim().replace(/^!+/, "");
  const cleanArguments = rawArguments.trim();

  if (cleanArguments || !cleanCommand.includes(" ")) {
    return {
      commandText: cleanCommand,
      argumentsText: cleanArguments,
    };
  }

  const [head, ...tail] = cleanCommand.split(/\s+/);
  return {
    commandText: head ?? "",
    argumentsText: tail.join(" "),
  };
}

export async function executeTwitchCommand(options: {
  req: NextApiRequest;
  guildId?: string | null;
  discordUser: DiscordBridgeUser;
  commandText: string;
  argumentsText?: string;
  isAdmin: boolean;
}): Promise<string> {
  const split = splitRawCommand(
    options.commandText,
    options.argumentsText ?? ""
  );
  const resolved = resolveTwitchCommand(split.commandText);

  if (!resolved.command) {
    return `❌ ${resolved.error ?? "Unknown Twitch command."}`;
  }

  const definition = resolved.command;

  if (definition.adminOnly && !options.isAdmin) {
    return `❌ /${definition.name} is restricted to Discord admins configured in DISCORD_ADMIN_USER_IDS.`;
  }

  const link = await getDiscordTwitchLink(
    options.guildId,
    options.discordUser.id
  );

  if (definition.requiresLink && !link) {
    return [
      `🔗 /${definition.name} uses player data and requires a Twitch link.`,
      "Ask a Discord admin to run /sols link with your Twitch username and numeric Twitch user ID.",
      "Public commands such as /info, /biome and /leaderboard work without a link.",
    ].join(" ");
  }

  const channelId =
    process.env.DEFAULT_CHANNEL_ID?.trim() || "904797805";
  const channelLogin =
    process.env.DEFAULT_CHANNEL_NAME?.trim().toLowerCase() || "zipittt";
  const channelDisplay =
    process.env.DEFAULT_CHANNEL_DISPLAY_NAME?.trim() ||
    process.env.DEFAULT_CHANNEL_NAME?.trim() ||
    "Zipittt";

  const providerId = link?.twitchUserId ?? options.discordUser.id;
  const username =
    link?.twitchUsername ?? options.discordUser.username;
  const displayName =
    link?.twitchDisplayName ??
    options.discordUser.globalName ??
    options.discordUser.username;

  const url = new URL(
    `/api/${definition.endpoint}`,
    requestOrigin(options.req)
  );

  if (split.argumentsText) {
    url.searchParams.set("query", split.argumentsText);
    url.searchParams.set("args", split.argumentsText);
  }

  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), 55_000);

  try {
    const response = await fetch(url, {
      method: "GET",
      headers: {
        "nightbot-user": encodeHeaderValues({
          name: username,
          displayName,
          provider: link ? "twitch" : "discord",
          providerId,
          userLevel: options.isAdmin ? "moderator" : "everyone",
        }),
        "nightbot-channel": encodeHeaderValues({
          name: channelLogin,
          displayName: channelDisplay,
          provider: "twitch",
          providerId: channelId,
        }),
        "x-discord-command-bridge": "1",
        "x-discord-user-id": options.discordUser.id,
      },
      signal: controller.signal,
    });

    const body = await response.text();

    if (!response.ok) {
      return cleanReply(
        `❌ /${definition.name} returned HTTP ${response.status}: ${body}`
      );
    }

    return cleanReply(body);
  } catch (error) {
    if (
      error instanceof Error &&
      (error.name === "AbortError" ||
        error.message.toLowerCase().includes("aborted"))
    ) {
      return `❌ /${definition.name} exceeded the 55-second Discord bridge limit. Try a smaller amount.`;
    }

    return `❌ /${definition.name} failed: ${
      error instanceof Error ? error.message : String(error)
    }`;
  } finally {
    clearTimeout(timeout);
  }
}
