    return truncate(`🌌 Reactor Lv.${reactor.level} | Active: ${formatAmount(reactor.activeDeposit.amount)} → ${formatAmount(reactor.activeDeposit.amount + profit)} | Ready in ${hours}h ${minutes}m`);
